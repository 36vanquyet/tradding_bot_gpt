# ===== Core =====
APP_ENV=dev
DB_PATH=bot_state.db
LOG_LEVEL=INFO
DRY_RUN=true

# ===== Trading =====
DEFAULT_EXCHANGE=binance
DEFAULT_SYMBOLS=BTC/USDT,ETH/USDT
DEFAULT_TIMEFRAME=1m
FAST_MA=5
SLOW_MA=20
RISK_PER_TRADE=0.01
PAPER_START_BALANCE=10000
POLL_INTERVAL_SECONDS=10
HEARTBEAT_SECONDS=300
MAX_OPEN_POSITIONS=3
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04
QUOTE_ASSET=USDT

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_CHAT_ID=

# ===== Binance =====
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# ===== Bybit =====
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# ===== MEXC =====
MEXC_API_KEY=
MEXC_API_SECRET=
MEXC_TESTNET=false
